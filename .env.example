# Email Configuration for Gmail SMTP
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=compareagentsirl@gmail.com
EMAIL_SMTP_PASS=your_app_password_here

# Email recipient (default)
EMAIL_TO=compareagentsirl@gmail.com
EMAIL_FROM=compareagentsirl@gmail.com

# Agent lead recipients. Customer/property leads are sent to each agent separately.
EMAIL_AGENT_TO=agent1@example.com,agent2@example.com

# Phone verification / SMS configuration
PHONE_VERIFICATION_SECRET=replace_with_a_long_random_secret
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+353000000000
# Or use this instead of TWILIO_FROM_NUMBER:
TWILIO_MESSAGING_SERVICE_SID=
